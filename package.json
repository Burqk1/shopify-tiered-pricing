{
  "name": "shopify-tiered-pricing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && remix vite:build",
    "dev": "shopify app dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "setup": "prisma generate && prisma migrate deploy",
    "postinstall": "prisma generate",
    "start": "remix-serve ./build/server/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc",
    "shopify": "shopify",
    "prisma": "prisma"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.2.0",
    "@prisma/client": "^6.19.0",
    "@remix-run/node": "^2.17.0",
    "@remix-run/react": "^2.17.0",
    "@remix-run/serve": "^2.17.0",
    "@shopify/app-bridge-react": "^4.2.0",
    "@shopify/polaris": "^13.9.0",
    "@shopify/shopify_function": "~2.0.0",
    "@shopify/shopify-api": "^12.2.0",
    "@shopify/shopify-app-remix": "^4.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^8.0.0",
    "@shopify/ui-extensions": "^2025.7.3",
    "@shopify/ui-extensions-react": "^2025.7.3",
    "isbot": "^5.1.0",
    "pg": "^8.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.17.0",
    "@shopify/cli": "^3.88.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.15.0",
    "jsdom": "^26.0.0",
    "prisma": "^6.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
